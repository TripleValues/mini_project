# ――――― [ 공용 설정 PART ] ――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――
FILE_PATH_ENV=D:\WorkSpace\02.github\mini_project
MY_HOST=192.168.0.104
MY_USER=root
MY_PWD=1234
MY_PORT=23306
SERVER_HOST=192.168.0.203
SERVER_USER=lnr
SERVER_PWD=lnr
SERVER_PORT=3306
API_KEY=4b7551556b6e6172393456434e4174

# ――――― [ Database 설정 (SQLAlchemy 및 Spark JDBC 공용) ] ―――――――――――――――――――――――――――――
# MARIADB_HOST=${MY_HOST}
# MARIADB_USER=${MY_USER}
# MARIADB_PASSWORD=${MY_PWD}
# MARIADB_PORT=${MY_PORT}
MARIADB_HOST=${SERVER_HOST}
MARIADB_USER=${SERVER_USER}
MARIADB_PASSWORD=${SERVER_PWD}
MARIADB_PORT=${SERVER_PORT}
MARIADB_NAME=db_metro

# ――――― [ SQLAlchemy용 URL (FastAPI에서 사용) ] ―――――――――――――――――――――――――――――――――――――――
MARIADB_URL=mysql+pymysql://${MARIADB_USER}:${MARIADB_PASSWORD}@${MARIADB_HOST}:${MARIADB_PORT}/${MARIADB_NAME}

# ――――― [ Spark 설정 ] ―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――
MARIADB_DRIVER=${FILE_PATH_ENV}\seoul_metro_v2\backend\mariadb-java-client-3.5.7.jar
SPARK_URL=spark://${MARIADB_HOST}:7077
HOST_IP=${MY_HOST}
JDBC_URL=jdbc:mariadb://${MARIADB_HOST}:${MARIADB_PORT}/${MARIADB_NAME}?sessionVariables=sql_mode='ANSI_QUOTES'

# ――――― [ 데이터 경로 ] ―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――
FILE_DIR=./data/raw

# ――――― [ HADOOP 경로 ] ―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――
HADOOP_PATH=${FILE_PATH_ENV}\seoul_metro_v2\backend

# ――――― [ REACT_URL 경로 ] ―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――
